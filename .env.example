# FCC Broadband Search - credentials
# Copy this file to .env and fill in your values.
#
# FCC_USERNAME  Your FCC account email / username
# FCC_API_KEY   Your FCC API key
#               Generate one at: https://broadbandmap.fcc.gov/home/profile
#               (Account > API Key)
#
# These are only needed if the FCC API requires authentication.
# Public provider-listing calls may work without them.

FCC_USERNAME=your_fcc_email@example.com
FCC_API_KEY=your_fcc_api_key

# Optional
PORT=5001
FLASK_DEBUG=1
