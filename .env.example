# FCC Broadband Data Collection (BDC) API credentials
# Copy this file to .env and fill in your values.
#
# How to get your API token:
#   1. Log in at https://broadbandmap.fcc.gov/login
#   2. Click your username (top right) → "Manage API Access"
#   3. Click "Generate" — this creates a 44-character API token
#
# FCC_USERNAME  Your FCC User Registration username (email address)
# FCC_API_KEY   The API token generated in step 3 above
#               (This is sent as the "hash_value" request header — NOT your password)
#
# Note: Your FRN (FCC Registration Number) is used when you FILE data,
# but it is NOT used for API authentication — use the token above instead.

FCC_USERNAME=your_fcc_email@example.com
FCC_API_KEY=your_44_character_api_token

# Optional
PORT=5001
FLASK_DEBUG=1
